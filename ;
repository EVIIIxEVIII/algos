#include <bits/stdc++.h>
using namespace std;

void solve(vector<int>& primes);

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t; cin >> t;
    vector<bool> is_prime(1e6+1, true);
    is_prime[0] = is_prime[1] = false;

    for (int i = 2; i <= 1e6; ++i) {
        if (is_prime[i]) {
            for (int j = 1LL*i*i; j <= 1e6; j+=i) {
                is_prime[j] = false;
            }
        }
    }
    vector<int> primes;
    for (int i = 2; i <= 1e6; ++i) {
        if (is_prime[i]) {
            primes.push_back(i);
        }
    }

    while (t--) solve(primes);

    return 0;
}

void solve(vector<int>& primes) {
    int n; cin >> n;


    for (int i = 0; i < n; ++i) {
        cout << primes[i] << ' ';
    }
    cout << '\n';
}
